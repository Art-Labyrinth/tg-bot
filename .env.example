# Copy to .env and fill in your values:  cp .env.example .env

# --- Telegram ---
BOT_TOKEN=123456:CHANGE_ME
# Telegram id of the root administrator (find your id via @userinfobot)
ADMIN_ID=0

# --- App ---
# DEBUG enables verbose logging (plain text instead of JSON)
DEBUG=true

# Postgres/Redis connection settings use the defaults from app/config.py
# (hosts "postgres"/"redis", db/user/password "tgbot") which match docker-compose.
# Override here only when running outside docker — e.g. generating migrations
# from the local venv needs the DB reachable on localhost:
# POSTGRES_HOST=localhost
